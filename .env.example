# Copy this file to `.env` and fill in your local LLM settings.
# `.env` is ignored by Git; do not commit real API keys.

# Presets: ollama | openai | deepseek | agicto | vllm_qwen3
LLM_PRESET=deepseek

# OpenAI-compatible chat completions base URL, without `/chat/completions`.
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=replace-with-your-api-key
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=120

# Optional aliases supported by the loader.
# OPENAI_BASE_URL=
# OPENAI_API_KEY=
# OPENAI_MODEL=

# Optional legacy clients in task_assets/utils/llm_client.
# LLAMA_BASE_URL=https://api.llama-api.com
# LLAMA_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
